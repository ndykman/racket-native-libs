{
  "name": "racket-native-libs",
  "version": "0.0.1",
  "dependencies": [
    {
      "name": "vcpkg-make",
      "host": true
    },
    {
      "name": "libjpeg-turbo",
      "features": [
        "jpeg8"
      ]
    },
    "argon2",
    "gettext",
    "gdk-pixbuf",
    "libffi",
    "libgit2",
    "libsass",
    "gmp",
    "mpfr",
    { 
      "name": "openssl",
      "features": [ "ssl3", "fips" ]
    },
    "sqlite3",
    "freetype",
    "harfbuzz",
    "fontconfig",
    "pango",
    "gtk3",
    { 
      "name": "poppler",
      "features": [
        "cairo",
        "glib"
      ]
    }
  ],
  "overrides": [
    {
      "name": "openssl",
      "version": "3.6.3#0"
    }
  ]
}