{
  "version": 3,
  "configurePresets": [
    {
        "name": "windows-base",
        "hidden": true,
        "generator": "Ninja",
        "binaryDir": "${sourceDir}/vs/build/${presetName}",
        "installDir": "${sourceDir}/vs/install/${presetName}",
        "cacheVariables": {
            "CMAKE_C_COMPILER": "cl.exe",
            "CMAKE_CXX_COMPILER": "cl.exe",
            "VCPKG_HOST_TRIPLET": "x64-windows-release",
            "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        "condition": {
            "type": "equals",
            "lhs": "${hostSystemName}",
            "rhs": "Windows"
        }
    },
    {
        "name": "mingw-base",
        "hidden": true,
        "generator": "Ninja",
        "binaryDir": "${sourceDir}/mingw/build/${presetName}",
        "installDir": "${sourceDir}/mingw/install/${presetName}",
        "cacheVariables": {   
            "CMAKE_C_COMPILER": "gcc",
            "CMAKE_CXX_COMPILER": "g++",        
            "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        "condition": {
            "type": "equals",
            "lhs": "${hostSystemName}",
            "rhs": "Linux"
        }
    },
    {
        "name": "linux-base",
        "generator": "Ninja",
        "binaryDir": "${sourceDir}/linux/build/${presetName}",
        "installDir": "${sourceDir}/linux/install/${presetName}",
        "cacheVariables": {   
            "CMAKE_C_COMPILER": "gcc",
            "CMAKE_CXX_COMPILER": "g++",        
            "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        "condition": {
            "type": "equals",
            "lhs": "${hostSystemName}",
            "rhs": "Linux"
        }
    },
    {
        "name": "osx-base",
        "generator": "Ninja",
        "binaryDir": "${sourceDir}/macos/build/${presetName}",
        "installDir": "${sourceDir}/macos/install/${presetName}",
        "cacheVariables": {    
            "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        "condition": {
            "type": "equals",
            "lhs": "${hostSystemName}",
            "rhs": "Darwin"
        }
    },
    {
        "name": "x64-release",
        "displayName": "x64 Release",
        "inherits": "windows-base",
        "architecture": {
            "value": "x64",
            "strategy": "external"
        },
        "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Release",
            "VCPKG_BUILD_TYPE": "release",
            "VCPKG_TARGET_TRIPLET": "x64-windows-release"
        }
    },
    {
        "name": "x86-release",
        "displayName": "x86 Release",
        "inherits": "windows-base",
        "architecture": {
            "value": "x86",
            "strategy": "external"
        },
        "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Release",
            "VCPKG_BUILD_TYPE": "release",
            "VCPKG_TARGET_TRIPLET": "x86-windows-release"
        }
    },
    {
        "name": "arm64-release",
        "displayName": "arm Release",
        "inherits": "windows-base",
        "architecture": {
            "value": "arm64",
            "strategy": "external"
        },
        "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Release",
            "VCPKG_TARGET_TRIPLET": "arm64-windows-release"
        }
    },
    {
      "name": "x64-mingw-release",
      "displayName": "x64 Release build on MSYS with MinGW (vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/msys/ucrt-release-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_BUILD_TYPE": "release",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
      }
    },
    {
      "name": "x86-mingw-release",
      "displayName": "x86 Release build on MSYS with MinGW (vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/msys/mingw-release-x86",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_BUILD_TYPE": "release",
        "VCPKG_TARGET_TRIPLET": "x86-mingw-dynamic"
      }
    },
    {
      "name": "arm64-mingw-release",
      "displayName": "arm64 Release build on MSYS with MinGW (vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/msys/mingw-release-arm64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_BUILD_TYPE": "release",
        "VCPKG_TARGET_TRIPLET": "arm64-mingw-dynamic"
      }
    },
    {
        "name": "x64-linux-release",
        "displayName": "x64 Linux Release",
        "inherits": "linux-base",
        "architecture": {
            "value": "x64",
            "strategy": "external"
        },
        "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Release",
            "VCPKG_BUILD_TYPE": "release",
            "VCPKG_TARGET_TRIPLET": "x64-linux-release"
        }
    },
    {
        "name": "arm64-osx-release",
        "displayName": "arm64 macOS Release",
        "inherits": "osx-base",
        "architecture": {
            "value": "arm64",
            "strategy": "external"
        },
        "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Release",
            "VCPKG_TARGET_TRIPLET": "arm64-osx-release"
        }
    }
  ]
}